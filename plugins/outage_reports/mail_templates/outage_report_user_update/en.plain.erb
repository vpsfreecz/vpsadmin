Hello <%= @user.login %>,

there is an update for the <%= @o.outage_type_label.downcase %> affecting your service.

<% @update.each_change do |attr, old, new| -%>
<%= case attr
    when :begins_at
      "Begins at: moved from #{old.localtime.strftime('%Y-%m-%d %H:%M %Z')} to #{new.localtime.strftime('%Y-%m-%d %H:%M %Z')}"
    when :finished_at
      "Finished at: #{new.localtime.strftime('%Y-%m-%d %H:%M %Z')}"
    when :duration
      "Duration: #{old} -> #{new} minutes"
    when :state
      "State: #{old} -> #{new}"
    when :impact_type
      "Impact type: #{Outage.impact_type_label(old)} -> #{Outage.impact_type_label(new)}"
    end
%>
<% end -%>

<%= @update.summary %>
<% if @update.description && !@update.description.empty? -%>

<%= @update.description %>
<% end -%>
<% if @update.reporter_name -%>

Reported by: <%= @update.reporter_name %>
<% end -%>

Best regards,

vpsAdmin
