#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
webui_root=$(CDPATH= cd -- "$script_dir/../.." && pwd)
domain=vpsAdmin
pot="$webui_root/lang/locale/$domain.pot"

if [ "$#" -ne 1 ]; then
    echo "Usage: webui/lang/scripts/new-lang <locale>" >&2
    echo "Example: webui/lang/scripts/new-lang cs_CZ.utf8" >&2
    exit 1
fi

if ! command -v msginit >/dev/null 2>&1; then
    echo "missing required gettext tool: msginit" >&2
    exit 1
fi

locale=$1
po_dir="$webui_root/lang/locale/$locale/LC_MESSAGES"
po="$po_dir/$domain.po"

if [ ! -f "$pot" ]; then
    "$script_dir/locales-update"
fi

mkdir -p "$po_dir"
msginit --input="$pot" --output-file="$po" --locale="$locale" --no-translator

echo "Created $po"
echo "Edit translations there, then run webui/lang/scripts/locales-update."
