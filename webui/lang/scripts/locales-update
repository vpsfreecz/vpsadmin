#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
webui_root=$(CDPATH= cd -- "$script_dir/../.." && pwd)
domain=vpsAdmin
pot="$webui_root/lang/locale/$domain.pot"

export LC_ALL=C.UTF-8

need_tool() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "missing required gettext tool: $1" >&2
        exit 1
    fi
}

generate_pot() {
    out="$1"
    tmp=$(mktemp)
    trap 'rm -f "$tmp"' EXIT INT TERM

    cd "$webui_root"

    # shellcheck disable=SC2046
    xgettext \
        --from-code=UTF-8 \
        --language=PHP \
        --keyword=_ \
        --keyword=N_ \
        --keyword=format_ngettext:1,2 \
        --flag=format_ngettext:1:php-format \
        --flag=format_ngettext:2:php-format \
        --add-location=file \
        --sort-by-file \
        --omit-header \
        --package-name=vpsAdmin \
        --package-version=1.0.0 \
        --msgid-bugs-address=info@vpsfree.cz \
        --copyright-holder=vpsFree.cz \
        -o "$tmp" \
        $(find . \
            -path './vendor' -prune -o \
            -path './lang' -prune -o \
            -path './tests' -prune -o \
            -name '*.php' -print | sort)

    {
        cat <<'EOF'
# This file is generated by webui/lang/scripts/locales-update.
# Do not edit it manually; manual changes will be overwritten.
# Edit WebUI gettext strings in source and translations in
# webui/lang/locale/<locale>/LC_MESSAGES/vpsAdmin.po.
msgid ""
msgstr ""
"Project-Id-Version: vpsAdmin 1.0.0\n"
"Report-Msgid-Bugs-To: info@vpsfree.cz\n"
"PO-Revision-Date: YEAR-MO-DA HO:MI+ZONE\n"
"Last-Translator: FULL NAME <EMAIL@ADDRESS>\n"
"Language-Team: LANGUAGE <LL@li.org>\n"
"Language: \n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"

EOF
        cat "$tmp"
    } > "$out"
}

need_tool xgettext
need_tool msgmerge
need_tool msgfmt

if [ "${1:-}" = "--check" ]; then
    tmp_pot=$(mktemp)
    trap 'rm -f "$tmp_pot"' EXIT INT TERM
    generate_pot "$tmp_pot"

    if ! cmp -s "$tmp_pot" "$pot"; then
        echo "$pot is stale; run webui/lang/scripts/locales-update" >&2
        diff -u "$pot" "$tmp_pot" >&2 || true
        exit 1
    fi

    "$script_dir/locales-health" --skip-pot
    exit 0
fi

generate_pot "$pot"

find "$webui_root/lang/locale" \
    -path '*/LC_MESSAGES/vpsAdmin.po' \
    -print | sort | while read -r po; do
        msgmerge --backup=none --previous --update "$po" "$pot"
    done

"$script_dir/locales-generate"
